# 制約管理エージェント — FastAPI バックエンド（Cloud Run 用）
#
# build context は **リポジトリ直下**（src/ data/ を COPY するため）。
#   gcloud builds submit --config deploy/cloudbuild.api.yaml ... .
# Cloud Run は環境変数 PORT（既定 8080）で待ち受ける必要がある。
FROM python:3.12-slim

WORKDIR /app

# 依存を先に入れてレイヤキャッシュを効かせる
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# アプリ本体（プロンプト *.txt も src 配下に含まれる）とデモデータ
COPY src ./src
COPY data ./data

ENV PORT=8080
# シェル形式にして $PORT を展開する（Cloud Run が注入）
CMD uvicorn src.api.main:app --host 0.0.0.0 --port $PORT
